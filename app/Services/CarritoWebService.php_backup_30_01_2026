                'formaPago' => 1,
                //'cupon' => 18, //este cupon fuerza a un 15% de decuento para toda la tienda es temporal
                'fecha_modificacion' => NOW()
            ];

            $carrito = Carrito::create($data);

            return ['data' => ['carrito' => $carrito->id]];
        }
    }

    /**
     * Recalcula las cantidades del carrito basándose en el stock disponible
     * Ajusta las cantidades si el stock es menor y elimina productos sin stock
     */
    public function recalcularCarritoPorStock($carritoId)
    {
        try {
            $detalles = Carritodetalle::where('carrito', $carritoId)->get();
            $productosActualizados = 0;
            $productosEliminados = 0;

            foreach ($detalles as $detalle) {
                $producto = Producto::where('id', $detalle->producto)->first();

                if (!$producto) {
                    // Si el producto no existe, eliminar el detalle
                    $detalle->delete();
                    $productosEliminados++;
                    Log::warning('CarritoWebService::recalcularCarritoPorStock - Producto no encontrado, eliminado del carrito', [
                        'carrito_id' => $carritoId,
                        'producto_id' => $detalle->producto,
                        'detalle_id' => $detalle->id
                    ]);
                    continue;
                }

                $stockDisponible = $producto->stock ?? 0;
                $cantidadSolicitada = $detalle->cantidad;

                // Si la cantidad solicitada es mayor que el stock disponible
                if ($cantidadSolicitada > $stockDisponible) {
                    if ($stockDisponible <= 0) {
                        // Si no hay stock, eliminar el detalle del carrito
                        $detalle->delete();
                        $productosEliminados++;
                        Log::info('CarritoWebService::recalcularCarritoPorStock - Producto sin stock eliminado del carrito', [
                            'carrito_id' => $carritoId,
                            'producto_id' => $detalle->producto,
                            'cantidad_solicitada' => $cantidadSolicitada,
                            'stock_disponible' => $stockDisponible
                        ]);
                    } else {
                        // Si hay stock pero menor, ajustar la cantidad
                        $detalle->cantidad = $stockDisponible;
                        $detalle->save();
                        $productosActualizados++;
                        Log::info('CarritoWebService::recalcularCarritoPorStock - Cantidad ajustada por stock insuficiente', [
                            'carrito_id' => $carritoId,
                            'producto_id' => $detalle->producto,
                            'cantidad_anterior' => $cantidadSolicitada,
                            'cantidad_nueva' => $stockDisponible,
                            'stock_disponible' => $stockDisponible
                        ]);
                    }
                }
            }

            // Actualizar fecha de modificación del carrito
            Carrito::where('id', $carritoId)->update(['fecha_modificacion' => now()]);

            if ($productosActualizados > 0 || $productosEliminados > 0) {
                Log::info('CarritoWebService::recalcularCarritoPorStock - Carrito recalculado', [
                    'carrito_id' => $carritoId,
                    'productos_actualizados' => $productosActualizados,
                    'productos_eliminados' => $productosEliminados
                ]);
            }

            return [
                'productos_actualizados' => $productosActualizados,
                'productos_eliminados' => $productosEliminados
            ];
        } catch (\Exception $e) {
            Log::error('CarritoWebService::recalcularCarritoPorStock - Error al recalcular carrito', [
                'carrito_id' => $carritoId,
                'error' => $e->getMessage()
            ]);
            // No lanzar excepción para no interrumpir el flujo, solo loguear el error
            return [
                'productos_actualizados' => 0,
                'productos_eliminados' => 0,
                'error' => $e->getMessage()
            ];
        }
    }

    public function findCarritoDetalle($id)
    {
        // Recalcular el carrito basándose en el stock disponible antes de calcular los totales
        $recalculoInfo = $this->recalcularCarritoPorStock($id);

        $transformer = new FindAllTransformer();
        if ($transformer) {
            $data = $transformer->transform($id);
            
            // Agregar información sobre el recálculo si hubo cambios
            if ($recalculoInfo['productos_actualizados'] > 0 || $recalculoInfo['productos_eliminados'] > 0) {
                $data['recalculoStock'] = [
                    'huboCambios' => true,
                    'productos_actualizados' => $recalculoInfo['productos_actualizados'],
                    'productos_eliminados' => $recalculoInfo['productos_eliminados']
                ];
            } else {
                $data['recalculoStock'] = [
                    'huboCambios' => false,
                    'productos_actualizados' => 0,
                    'productos_eliminados' => 0
                ];
            }
            
            return response()->json(['data' => $data], Response::HTTP_OK);
        } else {
            return response()->json(['message' => 'No se encontraron datos'], Response::HTTP_NOT_FOUND);
        }
    }

    public function create(Request $request)
    {
        $data = $request->all();

        $carrito = Carrito::create($data);

        if (!$carrito) {
            return response()->json(['error' => 'Failed to create Carrito'], Response::HTTP_INTERNAL_SERVER_ERROR);
        }

        return response()->json($carrito, Response::HTTP_OK);
    }

    public function update(Request $request)
    {
        $carrito = Carrito::find($request->id);

        if (!$carrito) {
            return response()->json(['error' => 'Carrito not found'], Response::HTTP_NOT_FOUND);
        }

        $carrito->update($request->all());
        $carrito->refresh();

        return response()->json($carrito, Response::HTTP_OK);
    }

    public function delete(Request $request)
    {
        $carrito = Carrito::find($request->id);

        if (!$carrito) {
            return response()->json(['error' => 'Carrito not found'], Response::HTTP_NOT_FOUND);
        }

        $carrito->delete();

        return response()->json(['id' => $request->id], Response::HTTP_OK);
    }

